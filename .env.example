# Copie para .env e preencha antes de rodar

SECRET_KEY=troque-por-uma-chave-segura-aqui
DEBUG=False
ALLOWED_HOSTS=seudominio.railway.app,localhost

# Railway fornece essa URL automaticamente ao adicionar PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Railway fornece ao adicionar Redis
REDIS_URL=redis://default:password@host:6379

# Frontend URL (para CORS)
CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app,http://localhost:5173
